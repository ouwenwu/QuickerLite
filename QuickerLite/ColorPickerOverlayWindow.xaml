<Window x:Class="QuickerLite.ColorPickerOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="#22000000"
        Topmost="True"
        ShowInTaskbar="False"
        Cursor="Cross"
        KeyDown="Window_KeyDown"
        MouseMove="Window_MouseMove"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Canvas x:Name="OverlayCanvas">
        <TextBlock Text="移动鼠标取色，单击确认，Esc 取消"
                   Canvas.Left="18"
                   Canvas.Top="18"
                   Foreground="White"
                   Background="#99000000"
                   Padding="10,6"
                   FontSize="14"/>

        <Border x:Name="MagnifierBorder"
                Width="188"
                Height="220"
                Background="#F5FFFFFF"
                BorderBrush="#FF2D8CFF"
                BorderThickness="1"
                CornerRadius="6"
                Padding="4"
                IsHitTestVisible="False">
            <StackPanel>
                <Grid Width="180" Height="180" ClipToBounds="True">
                    <Image x:Name="MagnifierImage"
                           Width="180"
                           Height="180"
                           Stretch="Fill"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    <Line X1="90" Y1="0" X2="90" Y2="180" Stroke="#CCFFFFFF" StrokeThickness="1"/>
                    <Line X1="0" Y1="90" X2="180" Y2="90" Stroke="#CCFFFFFF" StrokeThickness="1"/>
                    <Rectangle Width="12"
                               Height="12"
                               Stroke="#FFFF2D2D"
                               StrokeThickness="2"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>
                <DockPanel Margin="0,5,0,0">
                    <Border x:Name="CurrentColorPreview"
                            Width="28"
                            Height="22"
                            BorderBrush="#FF999999"
                            BorderThickness="1"
                            DockPanel.Dock="Left"/>
                    <TextBlock x:Name="CurrentColorText"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="#FF222222"/>
                </DockPanel>
            </StackPanel>
        </Border>
    </Canvas>
</Window>
