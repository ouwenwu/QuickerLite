<Window x:Class="QuickerLite.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:QuickerLite.Models"
        Title="Quicker Lite"
        Icon="Assets/AppIcon.ico"
        Width="316"
        Height="596"
        MinWidth="316"
        MinHeight="420"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Deactivated="Window_Deactivated">
    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFFFF"/>
            <Setter Property="BorderBrush" Value="#FFE8E8E8"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFF2F7FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FFE4EEFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate DataType="{x:Type models:ActionItem}">
            <Button Style="{StaticResource ActionButtonStyle}"
                    Click="ActionButton_Click"
                    PreviewMouseRightButtonUp="ActionButton_RightClick"
                    Tag="{Binding}">
                <Grid Width="74" Height="72">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="{Binding Icon}"
                               FontSize="25"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontFamily="Segoe UI Emoji"/>
                    <TextBlock Grid.Row="1"
                               Text="{Binding Title}"
                               FontSize="12"
                               Foreground="#FF181818"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </Grid>
            </Button>
        </DataTemplate>
    </Window.Resources>

    <Border Margin="8"
            Background="#FFFDFDFD"
            BorderBrush="#FFC6C6C6"
            BorderThickness="1"
            CornerRadius="7">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.28"/>
        </Border.Effect>

        <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="31"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="25"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#FFE1E1E1" CornerRadius="7,7,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="Quicker Lite"
                               Margin="9,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="13"
                               Foreground="#FF555555"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,7,0">
                        <TextBlock Text="○" Foreground="#FF858585" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="⚙" Foreground="#FF858585" FontSize="14" Margin="0,0,8,0"/>
                        <Button Content="×"
                                Width="21"
                                Height="21"
                                FontSize="15"
                                Foreground="#FF888888"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ItemsControl Grid.Row="1" ItemsSource="{Binding GlobalActions}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <Border Grid.Row="2" Background="#FFD6D6D6">
                <Grid>
                    <Grid VerticalAlignment="Center" Margin="5,0,92,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="📁" FontFamily="Segoe UI Emoji" FontSize="13" Margin="0,0,3,0"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding CurrentHeader}"
                                   Foreground="#FF666666"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                        <Button Grid.Column="2"
                                Content="禁用"
                                Width="42"
                                Height="19"
                                Margin="6,0,0,0"
                                Padding="0"
                                FontSize="11"
                                Foreground="#FF666666"
                                Background="#FFF2F2F2"
                                BorderBrush="#FFBFBFBF"
                                BorderThickness="1"
                                Cursor="Hand"
                                IsEnabled="{Binding CanDisableCurrentApp}"
                                ToolTip="以后在当前软件中保留中键原功能"
                                Click="DisableCurrentApp_Click"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                        <TextBlock Text="••" Foreground="#FF888888" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="⌕" Foreground="#FF8C8C8C" FontSize="17" Margin="0,0,8,0"/>
                        <TextBlock Text="🔒" FontFamily="Segoe UI Emoji" Foreground="#FF999999" FontSize="12"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="3">
                <ItemsControl ItemsSource="{Binding CurrentActions}" VerticalAlignment="Top">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <TextBlock Text="当前软件未配置"
                           Visibility="{Binding EmptyVisibility}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#FF888888"
                           FontSize="13"/>
            </Grid>
        </Grid>
    </Border>
</Window>
