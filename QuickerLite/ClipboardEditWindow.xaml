<Window x:Class="QuickerLite.ClipboardEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑剪贴板"
        Icon="Assets/AppIcon.ico"
        Width="560"
        Height="380"
        MinWidth="360"
        MinHeight="260"
        WindowStartupLocation="CenterOwner"
        Topmost="True"
        KeyDown="Window_KeyDown">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,8">
            <TextBlock Text="编辑剪贴板"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#FF333333"/>
            <TextBlock Text="Ctrl+Enter 保存，Esc 取消"
                       DockPanel.Dock="Right"
                       HorizontalAlignment="Right"
                       Foreground="#FF777777"
                       FontSize="12"/>
        </DockPanel>

        <Grid Grid.Row="1">
            <TextBox x:Name="ClipboardTextBox"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled"
                     Padding="8"
                     FontSize="14"/>

            <TextBlock x:Name="EmptyHintTextBlock"
                       Text="当前剪贴板不是文字，可直接输入新内容"
                       Margin="10"
                       Foreground="#FF888888"
                       IsHitTestVisible="False"
                       Visibility="Collapsed"/>
        </Grid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="确定"
                    Width="78"
                    Height="30"
                    Margin="0,0,8,0"
                    Click="OkButton_Click"/>
            <Button Content="取消"
                    Width="78"
                    Height="30"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
