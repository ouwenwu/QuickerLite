<Window x:Class="QuickerLite.SoftwareListManageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:QuickerLite.Models"
        Title="软件列表管理"
        Icon="Assets/AppIcon.ico"
        Width="640"
        Height="440"
        MinWidth="460"
        MinHeight="320"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
        </Style>

        <DataTemplate DataType="{x:Type models:SoftwareItem}">
            <Border BorderBrush="#FFE6E6E6"
                    BorderThickness="0,0,0,1"
                    Padding="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="42"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Image Source="{Binding IconPath}"
                           Width="32"
                           Height="32"
                           Stretch="Uniform"
                           VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Margin="8,0">
                        <TextBlock Text="{Binding Name}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#FF222222"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding Path}"
                                   FontSize="11"
                                   Foreground="#FF777777"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <Button Grid.Column="2"
                            Content="删除"
                            Tag="{Binding}"
                            Click="DeleteButton_Click"/>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="常用软件列表"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="#FF333333"
                   Margin="0,0,0,10"/>

        <Border Grid.Row="1"
                BorderBrush="#FFD6D6D6"
                BorderThickness="1"
                Background="White">
            <Grid>
                <ListBox ItemsSource="{Binding SoftwareItems}"
                         BorderThickness="0"/>
                <TextBlock Text="还没有添加软件"
                           Visibility="{Binding EmptyVisibility}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#FF888888"/>
            </Grid>
        </Border>

        <DockPanel Grid.Row="2" Margin="0,12,0,0" LastChildFill="False">
            <Button Content="关闭"
                    DockPanel.Dock="Right"
                    Click="CloseButton_Click"/>
            <Button Content="从窗口添加"
                    DockPanel.Dock="Right"
                    Click="AddFromWindowButton_Click"/>
            <Button Content="从文件添加"
                    DockPanel.Dock="Right"
                    Click="AddFromFileButton_Click"/>
        </DockPanel>
    </Grid>
</Window>
