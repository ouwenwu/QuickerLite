<Window x:Class="QuickerLite.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="屏幕取色"
        Icon="Assets/AppIcon.ico"
        Width="420"
        Height="310"
        MinWidth="360"
        MinHeight="280"
        WindowStartupLocation="CenterOwner"
        Topmost="True"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style x:Key="SwatchButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderBrush" Value="#FFAAAAAA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,10">
            <TextBlock Text="屏幕取色"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Foreground="#FF333333"/>
            <TextBlock Text="取色后自动复制 HEX"
                       DockPanel.Dock="Right"
                       Foreground="#FF777777"
                       FontSize="12"/>
        </DockPanel>

        <Border Grid.Row="1"
                x:Name="ColorPreview"
                Height="58"
                BorderBrush="#FFBDBDBD"
                BorderThickness="1"
                CornerRadius="4"
                Margin="0,0,0,10"/>

        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Margin="0,0,8,0">
                <TextBlock Text="HEX" FontSize="11" Foreground="#FF777777"/>
                <TextBox x:Name="HexTextBox" IsReadOnly="True" Height="28" Padding="6,3"/>
            </StackPanel>
            <StackPanel Grid.Column="1">
                <TextBlock Text="RGB" FontSize="11" Foreground="#FF777777"/>
                <TextBox x:Name="RgbTextBox" IsReadOnly="True" Height="28" Padding="6,3"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="3">
            <TextBlock Text="基础色卡"
                       FontSize="12"
                       Foreground="#FF555555"
                       Margin="0,0,0,5"/>
            <WrapPanel x:Name="PalettePanel"/>
        </StackPanel>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="取色"
                    Width="76"
                    Height="30"
                    Margin="0,0,8,0"
                    Click="PickButton_Click"/>
            <Button Content="复制HEX"
                    Width="82"
                    Height="30"
                    Margin="0,0,8,0"
                    Click="CopyHexButton_Click"/>
            <Button Content="复制RGB"
                    Width="82"
                    Height="30"
                    Margin="0,0,8,0"
                    Click="CopyRgbButton_Click"/>
            <Button Content="关闭"
                    Width="76"
                    Height="30"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
