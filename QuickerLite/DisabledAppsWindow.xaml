<Window x:Class="QuickerLite.DisabledAppsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="禁用列表"
        Icon="Assets/AppIcon.ico"
        Width="360"
        Height="430"
        MinWidth="320"
        MinHeight="320"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="已禁用中键弹窗的软件"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Foreground="#FF333333"
                   Margin="0,0,0,10"/>

        <Border Grid.Row="1"
                BorderBrush="#FFD6D6D6"
                BorderThickness="1"
                Background="#FFFFFFFF">
            <Grid>
                <ListBox ItemsSource="{Binding DisabledApps}"
                         BorderThickness="0"
                         SelectionMode="Extended">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Content="{Binding ProcessName}"
                                      FontSize="13"
                                      Padding="4"
                                      VerticalContentAlignment="Center"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Text="当前没有禁用的软件"
                           Visibility="{Binding EmptyVisibility}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#FF888888"/>
            </Grid>
        </Border>

        <DockPanel Grid.Row="2" Margin="0,12,0,0" LastChildFill="False">
            <Button Content="关闭"
                    DockPanel.Dock="Right"
                    Click="CloseButton_Click"/>
            <Button Content="全部恢复"
                    DockPanel.Dock="Right"
                    IsEnabled="{Binding HasItems}"
                    Click="RestoreAllButton_Click"/>
            <Button Content="恢复选中"
                    DockPanel.Dock="Right"
                    IsEnabled="{Binding HasSelection}"
                    Click="RestoreSelectedButton_Click"/>
            <Button Content="全选"
                    DockPanel.Dock="Right"
                    IsEnabled="{Binding HasItems}"
                    Click="SelectAllButton_Click"/>
        </DockPanel>
    </Grid>
</Window>
